{
  "name": "art-gallery",
  "version": "0.1.0",
  "description": "A fast, lightweight desktop app for browsing local image collections",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3,sharp",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win --x64 && cp 'release/kArtGallery Setup 0.1.0.exe' ~/Library/CloudStorage/Dropbox/Misc/Apps/kArtGallery/",
    "dist": "npm run build && electron-builder --mac --win"
  },
  "build": {
    "appId": "com.kartgallery.app",
    "productName": "kArtGallery",
    "icon": "resources/icon.png",
    "npmRebuild": false,
    "beforePack": "./scripts/before-pack.js",
    "afterPack": "./scripts/after-pack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "resources/**/*"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.photography"
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "kyleyoungblom",
      "repo": "kArtGallery"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ]
  },
  "dependencies": {
    "@webtoon/psd": "^0.4.0",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.0",
    "electron-updater": "^6.8.3",
    "masonic": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sharp": "^0.31.1",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "optionalDependencies": {
    "@img/sharp-win32-x64": "^0.34.5"
  }
}
